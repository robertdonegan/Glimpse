{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Glimpse",
  "version": "0.1.0",
  "identifier": "com.glimpse.recorder",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Glimpse",
        "width": 1280,
        "height": 820,
        "minWidth": 380,
        "minHeight": 300
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "targets": "all",
    "icon": ["icons/icon.png"]
  }
}
